# Flask Configuration
FLASK_ENV=development
FLASK_SECRET_KEY=your-secure-secret-key-here
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"

# Upstox API Configuration
UPSTOX_ANALYTICS_TOKEN=your-upstox-analytics-token-here
# Get from: https://account.upstox.com/developer/apps#analytics

# CORS Configuration (allowed origins for Socket.IO connections)
CORS_ALLOWED_ORIGINS=http://localhost:5001
# For production, set to your actual domain(s), comma-separated:
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Session Cookie Security (production only - requires HTTPS)
SECURE_SESSION_COOKIE=false
# Set to 'true' only in production with HTTPS enabled
